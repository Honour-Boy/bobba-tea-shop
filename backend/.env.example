# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase service-role key (Project Settings -> API -> service_role).
# Server-side only — keep this secret, never expose it to the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Port the API server listens on (defaults to 5000 if unset).
PORT=5000

# Secret used to sign JWT access tokens. Use a long random string.
ACCESSTOKENSECRET=
