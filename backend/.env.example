# Leave CONNECTIONSTRING empty to use an automatic in-memory MongoDB (good for local dev).
# Set it to a MongoDB URI (e.g. a MongoDB Atlas connection string) to use a real database.
CONNECTIONSTRING=

# Port the API server listens on (defaults to 5000 if unset).
PORT=5000

# Secret used to sign JWT access tokens. Use a long random string.
ACCESSTOKENSECRET=
